{
  "name": "code-crawler-vscode",
  "displayName": "Code Crawler - AI Code Detection",
  "description": "Detect AI-written vs human-written code with real-time keystroke tracking",
  "version": "0.1.1",
  "publisher": "Not-for-vibe-coders",
  "repository": {
    "type": "git",
    "url": "https://github.com/sudhxan/code-crawler"
  },
  "icon": "icon.png",
  "keywords": [
    "ai",
    "detection",
    "code-analysis",
    "copilot",
    "cursor"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeCrawler.showReport",
        "title": "Code Crawler: Show Report"
      },
      {
        "command": "codeCrawler.resetTracking",
        "title": "Code Crawler: Reset Tracking"
      }
    ],
    "configuration": {
      "title": "Code Crawler",
      "properties": {
        "codeCrawler.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Code Crawler tracking"
        },
        "codeCrawler.aiThreshold": {
          "type": "number",
          "default": 0.5,
          "description": "AI detection threshold (0-1)"
        },
        "codeCrawler.showDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Show line-level authorship decorations"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeCrawler",
          "title": "Code Crawler",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "codeCrawler": [
        {
          "type": "webview",
          "id": "codeCrawler.sidebar",
          "name": "Analysis"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch --sourcemap",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.4.0"
  }
}